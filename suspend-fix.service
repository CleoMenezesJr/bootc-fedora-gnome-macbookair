# Fix for MacBook suspend/wakeup issue.
# Prevents spurious wakeups triggered by XHC1 (USB 3.0),
# EHC1 and EHC2 (USB 2.0, present on some A1466 models).
# LID0 is NOT disabled here — lid-wakeup-guard.sh handles spurious
# lid wakeups with rate limiting instead, so lid-open still wakes the system.
# Writing to /proc/acpi/wakeup toggles the state, so we check for *enabled
# before writing to avoid accidentally re-enabling a disabled source.
# Ref: https://github.com/rlatosky/mbp-ublue

[Unit]
Description=Fix for MacBook suspend wakeup issue
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/sh -c 'for src in XHC1 EHC1 EHC2; do grep -Eqw "$src.*\\*enabled" /proc/acpi/wakeup 2>/dev/null && echo "$src" > /proc/acpi/wakeup || true; done'

[Install]
WantedBy=multi-user.target
